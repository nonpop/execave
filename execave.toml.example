# Comprehensive baseline config for sandboxing most standard tools.
# Every entry is read-only unless noted. The sandbox starts empty
# (default-deny), so anything not listed here does not exist inside
# it (except /dev, /proc, and a private /tmp).

fs = [
  # -- Executables and shared libraries --
  # Read-only, system-managed, no user secrets. Binaries and shared
  # libraries (sh, libc, etc.); nothing runs without them.
  "ro:/usr",
  "ro:/lib",
  "ro:/lib64",
  "ro:/bin",
  "ro:/sbin",

  # -- Dynamic linker configuration --
  # Read-only linker metadata derived from ldconfig, no secrets. Without
  # ld.so.cache the linker may fail to find libraries. ld.so.conf(.d) is
  # the fallback when the cache is missing.
  "ro:/etc/ld.so.cache",
  "ro:/etc/ld.so.preload",
  "ro:/etc/ld.so.conf",
  "ro:/etc/ld.so.conf.d",

  # -- User/group identity --
  # World-readable by design; no password hashes (those are in shadow).
  # getpwuid/getgrgid fail without these, breaking anything that resolves
  # UIDs to names (git, ssh, build tools). nsswitch.conf tells glibc which
  # lookup backends to use.
  "ro:/etc/passwd",
  "ro:/etc/group",
  "ro:/etc/nsswitch.conf",

  # -- Timezone --
  # Only the system timezone name and binary tzdata. Without these, time
  # defaults to UTC  -- wrong timestamps everywhere.
  "ro:/etc/localtime",
  "ro:/etc/timezone",

  # -- DNS and network resolution --
  # resolv.conf for nameservers, hosts for local overrides (localhost),
  # host.conf/gai.conf for resolver behavior, protocols/services for
  # name-to-number mapping (getaddrinfo, getprotobyname). No credentials.
  # The proxy-tunnel bridge also needs these even under network namespace
  # isolation.
  "ro:/etc/hosts",
  "ro:/etc/resolv.conf",
  "ro:/etc/host.conf",
  "ro:/etc/gai.conf",
  "ro:/etc/protocols",
  "ro:/etc/services",

  # -- TLS certificate bundles --
  # Public CA roots only, no private keys. HTTPS verification (curl, git,
  # pip, npm, ...) fails without them. Scoped to avoid /etc/ssl/private
  # and /etc/pki/tls/private which hold private keys.
  #
  # NOTE: custom/corporate CAs installed via update-ca-certificates or
  # update-ca-trust are compiled into these same bundles and will be
  # visible to the sandboxed process. This is unavoidable without
  # breaking HTTPS verification entirely.
  #
  "ro:/etc/ssl/certs",
  "ro:/etc/pki/tls/certs",
  "ro:/etc/pki/ca-trust",
  "ro:/etc/ca-certificates",

  # -- Log visibility (monitor only) --
  # Hide known-harmless denied entries from the --monitor web UI.
  # Useful for noisy paths you've already reviewed and accepted.
  # Does not affect access enforcement — only display.
  #
  # "nolog:/etc/fonts",

  # -- Working directory --
  # The only read-write entry. "." resolves to the config file's directory.
  # Scoped to one directory; everything outside remains inaccessible. The
  # sandboxed process must read and write project files.
  "rw:.",
  "ro:.git",
]

# net = [
#   # Log visibility for network rules (uncomment to use)
#   # "nolog:telemetry.example.com:*",
# ]

# syscall = [
#   # Seccomp overrides (uncomment to use)
#   # "allow:keyctl",
# ]
