package rules_test

import (
	"os"
	"path/filepath"
	"testing"

	"github.com/nonpop/execave/internal/config"
	"github.com/nonpop/execave/internal/rules"
	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

func TestCheckAccess_RelativeSymlinkChainBug(t *testing.T) {
	// Create test structure:
	// /tmp/test/link-dir -> real-dir        (RELATIVE symlink)
	// /tmp/test/real-dir -> final-target    (RELATIVE symlink - THIS ONE SHOULD BE DETECTED)
	// /tmp/test/final-target/file.txt       (actual file)

	tmpDir := t.TempDir()
	finalDir := filepath.Join(tmpDir, "final-target")
	realDirPath := filepath.Join(tmpDir, "real-dir")
	linkDirPath := filepath.Join(tmpDir, "link-dir")
	finalFile := filepath.Join(finalDir, "file.txt")
	
	// Create final target
	err := os.Mkdir(finalDir, 0o755)
	require.NoError(t, err)
	err = os.WriteFile(finalFile, []byte("content"), 0o644)
	require.NoError(t, err)
	
	// Create relative symlink: real-dir -> final-target
	err = os.Symlink("final-target", realDirPath)
	require.NoError(t, err)
	
	// Create relative symlink: link-dir -> real-dir
	err = os.Symlink("real-dir", linkDirPath)
	require.NoError(t, err)
	
	// Create resolver
	cfg := &config.Config{
		Rules: []config.Rule{
			{
				Resource:   config.ResourceFS,
				Permission: config.PermissionReadOnly,
				Path:       tmpDir,
				RawRule:    "fs:ro:" + tmpDir,
			},
		},
		ManagedPaths: nil,
	}
	resolver := rules.New(cfg)
	
	// Check access to file through the chain
	linkPath := filepath.Join(linkDirPath, "file.txt")
	result := resolver.CheckAccess(linkPath, rules.OperationRead)
	
	// We expect TWO hops in the symlink chain:
	// 1. link-dir -> real-dir
	// 2. real-dir -> final-target
	
	require.NotNil(t, result.Symlink, "Expected symlink chain to be recorded")
	
	// THIS ASSERTION WILL FAIL if the bug exists
	// The bug: relative symlink branch skips re-checking the resolved target
	// So we'll get 1 hop instead of 2
	assert.Len(t, result.Symlink.Hops, 2,
		"Expected 2 symlink hops (link-dir -> real-dir -> final-target), but got %d. "+
		"The second symlink (real-dir -> final-target) was not detected.",
		len(result.Symlink.Hops))
	
	if len(result.Symlink.Hops) >= 1 {
		assert.Equal(t, linkDirPath, result.Symlink.Hops[0].Path)
		assert.True(t, result.Symlink.Hops[0].Allowed)
	}
	
	if len(result.Symlink.Hops) >= 2 {
		assert.Equal(t, realDirPath, result.Symlink.Hops[1].Path)
		assert.True(t, result.Symlink.Hops[1].Allowed)
	}
	
	assert.Equal(t, finalFile, result.Symlink.ResolvedPath)
	assert.True(t, result.Allowed)
}
